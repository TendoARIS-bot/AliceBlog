---
import MainGridLayout from "../layouts/MainGridLayout.astro";

const pageTitle = "404 - 页面找不到了";

// 语录列表 - 每次修改博客时添加一条新语录
const quotes = [
  "迷失在数据的海洋里了吗？别担心，每个错误都是通往新发现的入口。——爱丽丝",
  "这个世界没有偶然，只有必然。你所遇到的每一个404，都是命运的安排。",
  "勇者啊，你走错路了！但这也许是一次全新的冒险开始？",
  "路标坏了，请换个方向继续你的旅程吧~",
  "这里什么都没有哦，就像爱丽丝的口袋一样空空的~",
  "邦邦卡邦！就算迷路了也不要紧，因为每一次迷路都是一场新的冒险！——爱丽丝",
];

// 随机选择一条语录
const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
---

<MainGridLayout title={pageTitle}>
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
        <div class="text-8xl font-bold text-[oklch(var(--hue)_0.5_0.7)] mb-6">
            404
        </div>
        <h1 class="text-2xl font-semibold mb-4">
            哇哦！这里什么都没有呢～
        </h1>
        <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md">
            {randomQuote}
        </p>
        
        <!-- 倒计时进度条 -->
        <div class="w-64 bg-gray-200 dark:bg-gray-700 rounded-full h-2 mb-6 overflow-hidden">
            <div id="countdown-bar" class="h-full bg-[oklch(var(--hue)_0.5_0.7)] transition-all duration-1000 ease-linear" style="width: 0%"></div>
        </div>
        
        <p class="text-sm text-gray-500 dark:text-gray-500 mb-6" id="countdown-text">
            5秒后自动跳转到首页...
        </p>
        
        <a 
            href="/" 
            class="px-6 py-3 bg-[oklch(var(--hue)_0.5_0.7)] text-white rounded-lg hover:bg-[oklch(var(--hue)_0.6_0.7)] transition-colors"
        >
            立即返回首页
        </a>
    </div>
</MainGridLayout>

<script>
// 5秒倒计时自动跳转
let countdown = 5;
const countdownText = document.getElementById('countdown-text');
const countdownBar = document.getElementById('countdown-bar');

const timer = setInterval(() => {
    countdown--;
    
    // 更新进度条
    const progress = ((5 - countdown) / 5) * 100;
    countdownBar.style.width = progress + '%';
    
    // 更新文本
    countdownText.textContent = countdown + '秒后自动跳转到首页...';
    
    if (countdown <= 0) {
        clearInterval(timer);
        window.location.href = '/';
    }
}, 1000);
</script>

<style is:global>
    /* 为 404 页面添加一些动画效果 */
    .text-8xl {
        animation: bounce 2s infinite;
    }
    
    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(-20px);
        }
        60% {
            transform: translateY(-10px);
        }
    }
</style>
